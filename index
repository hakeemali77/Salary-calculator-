<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#070b14">
<title>حاسبة الراتب</title>
<style>
:root{
  --bg:#060a14;--bg2:#0a1120;--surf:#0d1828;--surf2:#122035;--surf3:#182b42;
  --bdr:#1a2e48;--bdr2:#1f3a58;
  --gold:#f59e0b;--gold2:#fbbf24;--gold3:#fcd34d;--gdim:rgba(245,158,11,.14);--gdimG:rgba(245,158,11,.06);
  --green:#10b981;--gdimG2:rgba(16,185,129,.13);
  --blue:#3b82f6;--bdim:rgba(59,130,246,.12);
  --red:#ef4444;--rdim:rgba(239,68,68,.12);
  --purple:#8b5cf6;--pdim:rgba(139,92,246,.13);
  --txt:#eef2ff;--txt2:#94a3b8;--txt3:#475569;--txt4:#1e293b;
  --r:20px;--rs:14px;--rx:10px;--hh:88px;--nh:72px;--sb:env(safe-area-inset-bottom,0px);
  --glow-g:0 0 24px rgba(245,158,11,.15);--glow-b:0 0 24px rgba(59,130,246,.15)
}
[data-theme="light"]{
  --bg:#f1f5fb;--bg2:#e8edf7;--surf:#ffffff;--surf2:#f4f7fc;--surf3:#e8edf7;
  --bdr:#d1dae8;--bdr2:#bcc8da;
  --gdim:rgba(245,158,11,.12);--gdimG:rgba(245,158,11,.05);--gdimG2:rgba(16,185,129,.10);
  --bdim:rgba(59,130,246,.10);--rdim:rgba(239,68,68,.10);--pdim:rgba(139,92,246,.10);
  --txt:#0c1524;--txt2:#374151;--txt3:#6b7280;--txt4:#9ca3af;
  --glow-g:0 2px 12px rgba(245,158,11,.12);--glow-b:0 2px 12px rgba(59,130,246,.1)
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{height:100%;width:100%;overflow:hidden;background:var(--bg);font-family:-apple-system,'SF Pro Text','Helvetica Neue',Arial,sans-serif;color:var(--txt);transition:background .3s,color .3s}
.glass{background:rgba(255,255,255,.04);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px)}
[data-theme="light"] .glass{background:rgba(255,255,255,.7)}
#app{height:100dvh;position:relative;overflow:hidden}
.screen{position:absolute;inset:0;display:flex;flex-direction:column;opacity:0;pointer-events:none;transform:translateY(10px);transition:opacity .25s,transform .25s}
.screen.active{opacity:1;pointer-events:all;transform:translateY(0)}
/* ONBOARDING */
#obScreen{background:var(--bg);justify-content:flex-end;padding-bottom:calc(var(--sb) + 36px)}
.ob-bg{position:absolute;inset:0;overflow:hidden;pointer-events:none}
.ob-orb{position:absolute;border-radius:50%;filter:blur(80px);opacity:.16}
.ob-orb1{width:380px;height:380px;background:var(--gold);top:-100px;right:-80px;animation:orbF 6s ease-in-out infinite}
.ob-orb2{width:280px;height:280px;background:var(--blue);bottom:80px;left:-80px;animation:orbF 8s ease-in-out infinite reverse}
@keyframes orbF{0%,100%{transform:translateY(0)}50%{transform:translateY(-18px)}}
.ob-slides{flex:1;position:relative;overflow:hidden}
.ob-slide{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 28px 16px;opacity:0;transform:translateX(36px);transition:opacity .38s,transform .38s;text-align:center}
.ob-slide.active{opacity:1;transform:translateX(0)}
.ob-slide.exit{opacity:0;transform:translateX(-36px)}
.ob-icon{font-size:68px;margin-bottom:22px;animation:iconB 2.5s ease-in-out infinite}
@keyframes iconB{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.ob-title{font-size:28px;font-weight:800;color:var(--txt);margin-bottom:14px;line-height:1.3}
.ob-acc{color:var(--gold)}
.ob-desc{font-size:15px;color:var(--txt2);line-height:1.8;max-width:310px}
.ob-badge{display:inline-flex;align-items:center;gap:7px;background:var(--gdimG);border:1px solid rgba(16,185,129,.25);border-radius:30px;padding:8px 18px;font-size:13px;color:var(--green);font-weight:600;margin-top:18px}
.ob-dots{display:flex;justify-content:center;gap:8px;padding:18px 0 14px}
.ob-dot{height:6px;border-radius:3px;background:var(--bdr2);transition:all .3s;width:6px}
.ob-dot.active{width:24px;background:var(--gold)}
.ob-nav{padding:0 20px;display:flex;gap:10px}
.ob-skip{flex:1;padding:14px;border-radius:var(--rs);border:1px solid var(--bdr2);background:var(--surf2);color:var(--txt2);font-size:15px;font-family:inherit;cursor:pointer;font-weight:500}
.ob-next{flex:2;padding:14px;border-radius:var(--rs);border:none;background:linear-gradient(135deg,var(--gold),var(--gold2));color:#000;font-size:16px;font-weight:700;font-family:inherit;cursor:pointer;box-shadow:0 4px 20px rgba(245,158,11,.32)}
/* SETUP */
#setupScreen{overflow-y:auto;-webkit-overflow-scrolling:touch}
#setupScreen::-webkit-scrollbar{display:none}
.setup-top{padding:54px 22px 18px;text-align:center}
.setup-icon{font-size:46px;margin-bottom:10px}
.setup-title{font-size:22px;font-weight:800}
.setup-sub{font-size:14px;color:var(--txt2);margin-top:5px;line-height:1.6}
.setup-body{padding:0 14px calc(var(--sb) + 36px)}
.setup-sec{background:var(--surf);border:1px solid var(--bdr);border-radius:var(--r);padding:18px;margin-bottom:12px}
.sec-lbl{font-size:11px;font-weight:700;color:var(--txt3);text-transform:uppercase;letter-spacing:.6px;margin-bottom:14px;display:flex;align-items:center;gap:6px}
.flds{display:flex;flex-direction:column;gap:12px}
.flbl{font-size:13px;color:var(--txt2);font-weight:500;margin-bottom:6px}
.finput{width:100%;background:var(--surf2);border:1.5px solid var(--bdr);border-radius:var(--rs);padding:13px 14px;font-size:16px;color:var(--txt);font-family:inherit;outline:none;transition:border-color .2s;direction:ltr;text-align:right;-webkit-appearance:none}
.finput:focus{border-color:var(--gold)}
.finput::placeholder{color:var(--txt3)}
[lang="en"] .finput{text-align:left}
.lang-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.lang-opt{padding:12px;border-radius:var(--rx);border:1.5px solid var(--bdr);background:var(--surf2);text-align:center;cursor:pointer;font-size:14px;font-weight:600;color:var(--txt2);font-family:inherit}
.lang-opt.sel{border-color:var(--gold);background:var(--gdim);color:var(--gold)}
.btn-main{width:100%;background:linear-gradient(135deg,var(--gold),var(--gold2));color:#000;border:none;border-radius:var(--rs);padding:16px;font-size:17px;font-weight:700;font-family:inherit;cursor:pointer;margin-top:4px}
/* HEADER */
.app-hdr{height:var(--hh);padding:44px 16px 10px;background:rgba(7,11,20,.92);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid var(--bdr);display:flex;align-items:flex-end;justify-content:space-between;flex-shrink:0;z-index:10}
[data-theme="light"] .app-hdr{background:rgba(240,244,248,.92)}
.hdr-l{display:flex;flex-direction:column;gap:2px}
.hdr-title{font-size:17px;font-weight:800}
.hdr-sub{font-size:11px;color:var(--txt2)}
.hdr-acts{display:flex;gap:7px}
.icon-btn{width:37px;height:37px;border-radius:var(--rx);border:1px solid var(--bdr2);background:var(--surf2);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px}
/* SCROLL */
.scroll-body{flex:1;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch;padding:12px 13px calc(var(--sb) + var(--nh) + 14px)}
.scroll-body::-webkit-scrollbar{display:none}
/* BOTTOM NAV */
.bot-nav{position:absolute;bottom:0;left:0;right:0;height:calc(var(--nh) + var(--sb));background:var(--surf);border-top:1px solid var(--bdr);display:flex;z-index:20}
.nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;padding-top:10px;gap:4px;cursor:pointer;border:none;background:none;color:var(--txt3);font-family:inherit;font-size:11px;position:relative}
.nav-icon{font-size:22px;transition:transform .2s}
.nav-btn.active{color:var(--gold)}
.nav-btn.active .nav-icon{transform:scale(1.18) translateY(-1px)}
.nav-pip{position:absolute;top:5px;width:4px;height:4px;border-radius:2px;background:var(--gold);opacity:0;transition:opacity .2s}
.nav-btn.active .nav-pip{opacity:1}
/* COUNTDOWN */
/* ── WIDGET ── */
.widget{border-radius:var(--r);padding:0;margin-bottom:12px;position:relative;overflow:hidden;background:linear-gradient(145deg,#0c1e3e 0%,#091628 50%,#0e1f35 100%);border:1px solid rgba(245,158,11,.18);box-shadow:var(--glow-g)}
[data-theme="light"] .widget{background:linear-gradient(145deg,#fffbeb 0%,#fef9ec 50%,#fffbeb 100%);border-color:rgba(245,158,11,.3);box-shadow:0 4px 24px rgba(245,158,11,.12)}
.widget::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 80% 0%,rgba(245,158,11,.08) 0%,transparent 60%);pointer-events:none}
.widget-top{padding:18px 18px 14px;border-bottom:1px solid rgba(245,158,11,.1)}
.widget-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.widget-badge{font-size:10px;font-weight:700;color:var(--gold);background:rgba(245,158,11,.12);border:1px solid rgba(245,158,11,.2);border-radius:20px;padding:3px 10px;letter-spacing:.4px;text-transform:uppercase}
.widget-period{font-size:11px;color:var(--txt2)}
.widget-salary-row{display:flex;align-items:baseline;gap:6px}
.widget-salary{font-size:36px;font-weight:800;color:var(--gold);letter-spacing:-1.5px;line-height:1;direction:ltr}
.widget-curr{font-size:15px;color:var(--gold);opacity:.7;font-weight:500}
.widget-note{font-size:11px;color:var(--txt2);margin-top:5px}
.widget-bottom{padding:14px 18px}
.cd-lbl{font-size:10px;font-weight:700;color:var(--txt2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px;opacity:.8}
.cd-blocks{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:10px}
.cd-block{background:rgba(0,0,0,.18);border:1px solid rgba(255,255,255,.06);border-radius:var(--rx);padding:10px 4px;text-align:center;transition:transform .1s}
[data-theme="light"] .cd-block{background:rgba(245,158,11,.07);border-color:rgba(245,158,11,.15)}
.cd-num{font-size:26px;font-weight:800;color:var(--gold);line-height:1;font-variant-numeric:tabular-nums}
.cd-sub{font-size:9px;color:var(--txt2);margin-top:3px;opacity:.7;text-transform:uppercase;letter-spacing:.3px}
.cd-prog-wrap{background:rgba(0,0,0,.25);border-radius:4px;height:4px;overflow:hidden;margin-bottom:8px}
[data-theme="light"] .cd-prog-wrap{background:rgba(0,0,0,.08)}
.cd-prog{height:100%;background:linear-gradient(90deg,#d97706,var(--gold),var(--gold3));border-radius:4px;transition:width .8s ease;position:relative}
.cd-prog::after{content:'';position:absolute;right:0;top:-1px;width:6px;height:6px;background:var(--gold3);border-radius:50%;box-shadow:0 0 6px var(--gold)}
.cd-footer{display:flex;justify-content:space-between}
.cd-ft{font-size:10px;color:var(--txt3)}
/* MONTH NAV */
.mnav{display:flex;align-items:center;gap:9px;background:var(--surf);border:1px solid var(--bdr);border-radius:var(--r);padding:11px 13px;margin-bottom:11px}
.mnav-btn{width:35px;height:35px;border-radius:10px;border:1px solid var(--bdr2);background:var(--surf2);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:17px;color:var(--txt2)}
.mnav-ctr{flex:1;text-align:center}
.mnav-name{font-size:16px;font-weight:800}
.mnav-sub{font-size:11px;color:var(--txt2);margin-top:2px}
/* DATE RANGE */
.drange{background:var(--surf);border:1px solid var(--bdr);border-radius:var(--rs);padding:13px 15px;margin-bottom:11px;display:flex;align-items:center;justify-content:space-between}
.dr-pt{text-align:center;flex:1}
.dr-lbl{font-size:10px;color:var(--txt2);margin-bottom:3px}
.dr-val{font-size:14px;font-weight:700;direction:ltr}
.dr-hij{font-size:10px;color:var(--gold);margin-top:2px;direction:rtl;opacity:.85}
.dr-arr{font-size:20px;color:var(--txt3);padding:0 6px}
/* STATS */
.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:11px}
.stat{background:var(--surf);border:1px solid var(--bdr);border-radius:var(--rs);padding:13px 8px;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,.15)}
.stat-v{font-size:24px;font-weight:800;line-height:1;margin-bottom:4px}
.stat-l{font-size:11px;color:var(--txt2);line-height:1.3}
.stat.blue{border-color:rgba(59,130,246,.25)}.stat.blue .stat-v{color:var(--blue)}
.stat.green{border-color:rgba(16,185,129,.25)}.stat.green .stat-v{color:var(--green)}
.stat.gold{border-color:rgba(245,158,11,.25)}.stat.gold .stat-v{color:var(--gold)}
/* SALARY HERO */
.sh{background:var(--surf);border:1px solid var(--bdr);border-radius:var(--r);padding:18px;margin-bottom:11px;position:relative;overflow:hidden}
.sh::after{content:"﷼";position:absolute;top:-10px;left:8px;font-size:100px;color:var(--gold);opacity:.03;pointer-events:none;line-height:1}
.sh-lbl{font-size:11px;font-weight:700;color:var(--txt2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px}
.sh-amt{font-size:40px;font-weight:800;color:var(--gold);letter-spacing:-1px;line-height:1;direction:ltr;text-align:right}
[lang="en"] .sh-amt{text-align:left}
.sh-curr{font-size:17px;font-weight:500;opacity:.7;margin-left:3px}
.sh-note{font-size:12px;color:var(--txt2);margin-top:7px}
/* MONTHLY BREAKDOWN */
.month-sec{background:var(--surf);border:1px solid var(--bdr);border-radius:var(--r);padding:16px;margin-bottom:11px}
.card-title{font-size:13px;font-weight:700;color:var(--txt2);display:flex;align-items:center;gap:7px;margin-bottom:13px;text-transform:uppercase;letter-spacing:.4px}
.month-blk{background:var(--surf2);border:1px solid var(--bdr);border-radius:var(--rs);padding:13px 14px;margin-bottom:8px}
.month-blk:last-of-type{margin-bottom:0}
.month-blk-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:3px}
.month-blk-name{font-size:14px;font-weight:700}
.month-blk-hij{font-size:10px;color:var(--gold);opacity:.8;display:block;margin-bottom:8px}
.month-blk-tot{font-size:15px;font-weight:800;color:var(--gold);direction:ltr}
.bk-row{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--bdr)}
.bk-row:last-child{border-bottom:none}
.bk-l{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--txt2)}
.bk-dot{width:8px;height:8px;border-radius:3px;flex-shrink:0}
.bk-r{font-size:13px;font-weight:700;direction:ltr}
.grand-tot{display:flex;align-items:center;justify-content:space-between;background:var(--gdim);border:1px solid rgba(245,158,11,.2);border-radius:var(--rx);padding:12px 14px;margin-top:10px}
.grand-lbl{font-size:15px;font-weight:700;color:var(--gold)}
.grand-amt{font-size:20px;font-weight:800;color:var(--gold);direction:ltr}
/* CALENDAR */
.cal-card{background:var(--surf);border:1px solid var(--bdr);border-radius:var(--r);padding:13px;margin-bottom:11px}
.cal-month-title{font-size:13px;font-weight:700;margin-bottom:9px;text-align:center;padding:5px 0 8px;border-bottom:1px solid var(--bdr)}
.cal-wdays{display:grid;grid-template-columns:repeat(7,1fr);margin-bottom:5px}
.cal-wd{text-align:center;font-size:10px;font-weight:700;color:var(--txt3);padding:3px 0}
.cal-wd.fri{color:var(--gold)}
.cal-days{display:grid;grid-template-columns:repeat(7,1fr);gap:3px}
.cal-day{aspect-ratio:1;display:flex;align-items:center;justify-content:center;border-radius:8px;font-size:12px;font-weight:500;color:var(--txt4)}
.cal-empty{aspect-ratio:1}
.cal-day.is-off{color:var(--txt4)}
.cal-day.in-cycle{background:#1a2a4a;color:#c8daff;border:1px solid #2a4a7a;font-weight:600}
[data-theme="light"] .cal-day.in-cycle{background:#dbeafe;color:#1e40af;border:1px solid #93c5fd}
.cal-day.is-friday{background:rgba(245,158,11,.25);color:#f59e0b;border:1px solid rgba(245,158,11,.5);font-weight:700}
.cal-day.is-off-hol{background:rgba(239,68,68,.22);color:#f87171;border:1px solid rgba(239,68,68,.45);font-weight:700}
.cal-day.is-cust-hol{background:rgba(139,92,246,.22);color:#a78bfa;border:1px solid rgba(139,92,246,.45);font-weight:700}
.cal-day.is-reminder{background:rgba(251,191,36,.18);color:#fbbf24;border:1px solid rgba(251,191,36,.4);font-weight:600}
.cal-day.is-ext-hol{background:rgba(100,116,139,.15);color:var(--txt3);border:1px solid rgba(100,116,139,.25);font-size:10px}
.hol-badge.reminder{background:rgba(251,191,36,.15);color:#d97706;border:1px solid rgba(251,191,36,.3)}
.cal-day.is-today{outline:2.5px solid var(--gold);outline-offset:1px}
.cal-legend{display:flex;gap:10px;margin-top:10px;flex-wrap:wrap}
.cal-leg{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--txt2)}
.cal-leg-dot{width:9px;height:9px;border-radius:3px;flex-shrink:0}
/* CARD */
.card{background:var(--surf);border:1px solid var(--bdr);border-radius:var(--r);padding:16px;margin-bottom:11px}
/* HOLIDAY ITEMS */
.hol-item{background:var(--surf);border:1px solid var(--bdr);border-radius:var(--rs);padding:12px 13px;margin-bottom:7px;display:flex;align-items:center;gap:9px}
.hol-del{width:28px;height:28px;border-radius:8px;border:1px solid rgba(239,68,68,.25);background:var(--rdim);color:var(--red);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:13px;flex-shrink:0}
.hol-info{flex:1;min-width:0}
.hol-name{font-size:14px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.hol-date{font-size:11px;color:var(--txt2);direction:ltr;margin-top:2px}
.hol-badge{font-size:10px;font-weight:700;padding:3px 9px;border-radius:20px;flex-shrink:0}
.hol-badge.official{background:var(--gdim);color:var(--gold);border:1px solid rgba(245,158,11,.2)}
.hol-badge.custom{background:var(--bdim);color:var(--blue);border:1px solid rgba(59,130,246,.2)}
/* ADD FORM */
.add-form{background:var(--surf);border:1.5px dashed rgba(59,130,246,.3);border-radius:var(--r);padding:14px;margin-bottom:11px;display:none;flex-direction:column;gap:11px}
.add-form.open{display:flex}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px}
/* SETTINGS */
.set-hdr{font-size:11px;font-weight:700;color:var(--txt3);text-transform:uppercase;letter-spacing:.6px;padding:14px 3px 8px}
.set-row{background:var(--surf);border:1px solid var(--bdr);border-radius:var(--rs);padding:14px 15px;margin-bottom:7px;display:flex;align-items:center;justify-content:space-between;cursor:pointer}
.set-row-l{display:flex;align-items:center;gap:11px}
.set-ico{font-size:19px;width:35px;height:35px;display:flex;align-items:center;justify-content:center;background:var(--surf2);border-radius:10px;border:1px solid var(--bdr);flex-shrink:0}
.set-lbl{font-size:15px}
.set-sub{font-size:12px;color:var(--txt2);margin-top:2px}
.set-arr{font-size:14px;color:var(--txt3)}
.toggle-row{display:flex;background:var(--surf2);border:1px solid var(--bdr);border-radius:var(--rs);overflow:hidden;margin-bottom:7px}
.tog-opt{flex:1;padding:11px;text-align:center;font-size:14px;font-weight:600;color:var(--txt2);cursor:pointer;font-family:inherit;border:none;background:none}
.tog-opt.active{background:var(--surf3);color:var(--txt);border-radius:var(--rx)}
/* MODAL */
.modal-ov{position:fixed;inset:0;background:rgba(0,0,0,.65);backdrop-filter:blur(10px);z-index:200;display:flex;align-items:flex-end;opacity:0;pointer-events:none;transition:opacity .25s}
.modal-ov.open{opacity:1;pointer-events:all}
.modal-sheet{width:100%;background:var(--surf);border-top:1px solid var(--bdr);border-radius:22px 22px 0 0;padding:14px 18px calc(var(--sb) + 22px);transform:translateY(100%);transition:transform .3s cubic-bezier(.4,0,.2,1);max-height:82vh;overflow-y:auto}
.modal-sheet::-webkit-scrollbar{display:none}
.modal-ov.open .modal-sheet{transform:translateY(0)}
.modal-handle{width:40px;height:4px;background:var(--bdr2);border-radius:2px;margin:0 auto 16px}
.modal-title{font-size:18px;font-weight:800;text-align:center;margin-bottom:18px}
.modal-flds{display:flex;flex-direction:column;gap:13px}
/* BUTTONS */
.btn-row{display:flex;gap:9px}
.btn-s{flex:1;padding:12px;border-radius:var(--rx);font-size:14px;font-weight:700;font-family:inherit;cursor:pointer;border:none}
.btn-s.gold{background:linear-gradient(135deg,var(--gold),var(--gold2));color:#000}
.btn-s.ghost{background:var(--surf2);color:var(--txt);border:1px solid var(--bdr2)}
/* TOAST */
.toast{position:fixed;bottom:calc(var(--sb) + var(--nh) + 10px);left:50%;transform:translateX(-50%) translateY(14px);background:var(--surf3);border:1px solid var(--bdr2);border-radius:30px;padding:10px 20px;font-size:14px;font-weight:600;color:var(--txt);opacity:0;pointer-events:none;transition:all .28s;z-index:300;white-space:nowrap}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
/* SYNC */
.sync-bar{display:flex;align-items:center;gap:6px;padding:5px 2px 9px;font-size:11px;color:var(--txt3)}
.sync-dot{width:6px;height:6px;border-radius:50%;background:var(--green);flex-shrink:0}
@keyframes spin{to{transform:rotate(360deg)}}
.sync-dot.spin{animation:spin .7s linear infinite;background:var(--gold)}
.empty{text-align:center;padding:28px 16px;color:var(--txt3);font-size:14px}
.empty-icon{font-size:38px;margin-bottom:9px}
/* NOTES */
.notes-card{background:var(--surf);border:1px solid var(--bdr);border-radius:var(--r);padding:16px;margin-bottom:12px}
.notes-ta{width:100%;background:var(--surf2);border:1.5px solid var(--bdr);border-radius:var(--rs);padding:12px 14px;font-size:14px;color:var(--txt);font-family:inherit;outline:none;resize:none;min-height:80px;transition:border-color .2s;direction:rtl;line-height:1.6}
[lang="en"] .notes-ta{direction:ltr}
.notes-ta:focus{border-color:var(--gold)}
.notes-ta::placeholder{color:var(--txt3)}
.notes-saved{font-size:11px;color:var(--green);margin-top:5px;height:14px;transition:opacity .3s;opacity:0}
.notes-saved.show{opacity:1}
/* NOTIF SETTINGS */
.notif-row{display:flex;align-items:center;justify-content:space-between;padding:4px 0}
.notif-toggle{width:46px;height:26px;background:var(--bdr2);border-radius:13px;position:relative;cursor:pointer;transition:background .25s;border:none;flex-shrink:0}
.notif-toggle.on{background:var(--green)}
.notif-toggle::after{content:'';position:absolute;top:3px;left:3px;width:20px;height:20px;background:#fff;border-radius:50%;transition:transform .25s;box-shadow:0 1px 4px rgba(0,0,0,.3)}
.notif-toggle.on::after{transform:translateX(20px)}
.days-select{background:var(--surf2);border:1.5px solid var(--bdr);border-radius:var(--rx);padding:7px 12px;color:var(--txt);font-family:inherit;font-size:14px;outline:none;cursor:pointer;-webkit-appearance:none}
</style>
