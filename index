}

/* HOLIDAYS */
function renderHolsList(){
  var t=T[cfg.lang];var el=document.getElementById('holsList');if(!el)return;
  if(!holidays.length){el.innerHTML='<div class="empty"><div class="empty-icon">📅</div>'+t.noHols+'</div>';return;}
  var sorted=holidays.slice().sort(function(a,b){return a.from<b.from?-1:a.from>b.from?1:0;});
  var h='';
  for(var i=0;i<sorted.length;i++){
    var hh=sorted[i];var oi=holidays.indexOf(hh);
    h+='<div class="hol-item"><div class="hol-del" onclick="delHol('+oi+')">✕</div><div class="hol-info"><div class="hol-name">'+hh.name+'</div><div class="hol-date">'+hh.from+(hh.from!==hh.to?' \u2192 '+hh.to:'')+'</div></div><span class="hol-badge '+hh.type+'">'+(t[hh.type]||hh.type)+'</span></div>';
  }
  el.innerHTML=h;
}
function toggleAddForm(){var f=document.getElementById('addForm');if(f)f.classList.toggle('open');}
var _holType='custom';
function setHolType(type,btn){
  _holType=type;
  var hBtn=document.getElementById('af_type_hol');
  var rBtn=document.getElementById('af_type_rem');
  var hint=document.getElementById('af_hint');
  if(hBtn)hBtn.classList.toggle('active',type==='custom');
  if(rBtn)rBtn.classList.toggle('active',type==='reminder');
  if(hint){
    if(type==='custom'){hint.style.color='var(--green)';hint.textContent=cfg.lang==='ar'?'✅ ستُضاف للراتب وتظهر في التقويم':'✅ Will be added to salary and shown in calendar';}
    else{hint.style.color='var(--gold)';hint.textContent=cfg.lang==='ar'?'🔔 تذكير فقط — لن تؤثر على الراتب':'🔔 Reminder only — will not affect salary';}
  }
}
function addHol(){
  var name=document.getElementById('af_name').value.trim();
  var from=document.getElementById('af_from').value;
  var to=document.getElementById('af_to').value||from;
  if(!name||!from){showToast('⚠️ '+(cfg.lang==='ar'?'أدخل الاسم والتاريخ':'Enter name and date'));return;}
  holidays.push({name:name,from:from,to:to,type:_holType});save();renderHolsList();renderCycle(cycleIdx);
  document.getElementById('af_name').value='';document.getElementById('af_from').value='';document.getElementById('af_to').value='';
  var af=document.getElementById('addForm');if(af)af.classList.remove('open');
  showToast(T[cfg.lang].added);
}
function delHol(idx){
  if(idx<0||idx>=holidays.length)return;
  var name=holidays[idx].name;
  var msg=cfg.lang==='ar'?('حذف: '+name+'؟'):('Delete: '+name+'?');
  if(!window.confirm(msg))return;
  holidays.splice(idx,1);
  save();renderHolsList();renderCycle(cycleIdx);showToast(T[cfg.lang].deleted);
}

/* MODALS */
function openEditModal(){document.getElementById('em_base').value=cfg.base;document.getElementById('em_work').value=cfg.workRate;document.getElementById('em_hol').value=cfg.holRate;document.getElementById('editModal').classList.add('open');}
function saveEdit(){var b=parseFloat(document.getElementById('em_base').value);var w=parseFloat(document.getElementById('em_work').value);var h=parseFloat(document.getElementById('em_hol').value);if(isNaN(b)||isNaN(w)||isNaN(h)){showToast('⚠️');return;}cfg.base=b;cfg.workRate=w;cfg.holRate=h;save();closeModal('editModal');renderCycle(cycleIdx);updateSetDisplay();showToast(T[cfg.lang].saved);}
function openStartModal(){document.getElementById('sm_date').value=cfg.startDate||'';document.getElementById('startModal').classList.add('open');}
function saveStart(){var d=document.getElementById('sm_date').value;if(!d)return;cfg.startDate=d;save();closeModal('startModal');cycleIdx=getCurrentIdx();renderCycle(cycleIdx);startCD();updateSetDisplay();showToast(T[cfg.lang].saved);}
function closeModal(id){var el=document.getElementById(id);if(el)el.classList.remove('open');}
function closeOv(e,id){if(e.target&&e.target.id===id)closeModal(id);}

/* SYNC — XHR instead of fetch (better Safari compatibility) */
function syncHols(){
  var t=T[cfg.lang];setSyncSt(t.syncing,true);
  var years=[2024,2025,2026];var fetched=[];var done=0;
  function tryY(yr){
    var xhr=new XMLHttpRequest();
    xhr.open('GET','https://date.nager.at/api/v3/PublicHolidays/'+yr+'/SA',true);
    xhr.timeout=8000;
    function onDone(){done++;if(done===years.length)finish();}
    xhr.onload=function(){try{if(xhr.status===200){var data=JSON.parse(xhr.responseText);for(var i=0;i<data.length;i++)fetched.push({name:data[i].localName||data[i].name,from:data[i].date,to:data[i].date,type:'official'});}}catch(e){}onDone();};
    xhr.onerror=onDone;xhr.ontimeout=onDone;
    try{xhr.send();}catch(e){onDone();}
  }
  for(var i=0;i<years.length;i++)tryY(years[i]);
  function finish(){var t2=T[cfg.lang];if(fetched.length){var cust=[];for(var j=0;j<holidays.length;j++)if(holidays[j].type!=='official')cust.push(holidays[j]);holidays=cust.concat(fetched);save();renderCycle(cycleIdx);renderHolsList();setSyncSt(t2.syncDone+' ('+fetched.length+')',false);showToast(t2.synced);}else{setSyncSt(t2.local,false);showToast(t2.syncFail);}}
}
function setSyncSt(txt,loading){_s('syncTxt',txt);var d=document.getElementById('syncDot');if(d)d.className='sync-dot'+(loading?' spin':'');}

/* UTILS */
function fmt(n){try{return n.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});}catch(e){return n.toFixed(2);}}
function fmtD(d){return d.getDate()+'/'+(d.getMonth()+1)+'/'+d.getFullYear();}

