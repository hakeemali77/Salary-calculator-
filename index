/* CALENDAR */
function renderCal(start,end){
  var today=new Date();today.setHours(0,0,0,0);
  var t=T[cfg.lang];
  var wds=cfg.lang==='ar'?ARWD:ENWD;
  var months=cfg.lang==='ar'?ARM:ENM;
  var mks=[];
  var cur=new Date(start.getTime());
  while(cur<=end){
    var mk=cur.getFullYear()+'-'+(cur.getMonth()+1);
    var found=false;for(var fi=0;fi<mks.length;fi++){if(mks[fi]===mk){found=true;break;}}
    if(!found)mks.push(mk);
    cur.setDate(cur.getDate()+1);
  }
  var legs=[{bg:'#1a2a4a',bd:'1px solid #2a4a7a'},{bg:'rgba(245,158,11,.25)',bd:'1px solid rgba(245,158,11,.5)'},{bg:'rgba(239,68,68,.22)',bd:'1px solid rgba(239,68,68,.45)'},{bg:'rgba(139,92,246,.22)',bd:'1px solid rgba(139,92,246,.45)'},{bg:'rgba(251,191,36,.18)',bd:'1px solid rgba(251,191,36,.4)'},{bg:'transparent',bd:'2.5px solid var(--gold)'}];
  var h='';
  for(var mi=0;mi<mks.length;mi++){
    var parts=mks[mi].split('-');var yr=parseInt(parts[0]);var mo=parseInt(parts[1])-1;
    var tot=new Date(yr,mo+1,0).getDate();var fdow=new Date(yr,mo,1).getDay();
    var _mh=hijriShort(new Date(yr,mo,15));h+='<div class="cal-month-title">'+months[mo]+' '+yr+(_mh?'<div style="font-size:10px;color:var(--gold);opacity:.85;margin-top:2px">'+_mh+'</div>':'')+' </div>';
    h+='<div class="cal-wdays">';for(var wi=0;wi<7;wi++)h+='<div class="cal-wd'+(wi===5?' fri':'')+'">'+wds[wi]+'</div>';h+='</div>';
    h+='<div class="cal-days">';
    for(var ei=0;ei<fdow;ei++)h+='<div class="cal-empty"></div>';
    for(var day=1;day<=tot;day++){
      var d=new Date(yr,mo,day);var ds=d.toISOString().slice(0,10);
      var inC=d>=start&&d<=end;var ht=getHolType(ds);var isTod=d.getTime()===today.getTime();
      var cls='cal-day';
      if(!inC){
        if(ht==='official'||ht==='custom'||ht==='reminder') cls+=' is-ext-hol';
        else cls+=' is-off';
      } else if(ht==='official') cls+=' is-off-hol';
      else if(ht==='custom') cls+=' is-cust-hol';
      else if(ht==='reminder') cls+=' is-reminder';
      else if(d.getDay()===5) cls+=' is-friday';
      else cls+=' in-cycle';
      if(isTod)cls+=' is-today';
      h+='<div class="'+cls+'">'+day+'</div>';
    }
    h+='</div>';
