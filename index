  var months=cfg.lang==='ar'?ARM:ENM;
  _s('h_title',t.appTitle);
  _s('h_cycle',t.cycleNo+' '+(idx+1)+(idx===curIdx?' '+t.current:''));
  var sM=months[start.getMonth()],eM=months[end.getMonth()];
  _s('mn_name',sM===eM?sM:sM+' \u2014 '+eM);
  _s('mn_sub',start.getFullYear()===end.getFullYear()?String(start.getFullYear()):start.getFullYear()+' / '+end.getFullYear());
  _s('dr_s',fmtD(start));_s('dr_e',fmtD(end));
  _s('dr_sh',hijriLong(start));_s('dr_eh',hijriLong(end));
  var spSet=buildSpSet(start,end);
  var spC=Math.min(spSet.size,WORK);var nC=WORK-spC;
  _s('st_w',String(WORK));_s('st_s',String(spC));
  var segs=splitByMonth(start,end,spSet);
  var grand=0;for(var i=0;i<segs.length;i++)grand+=segs[i].mTot;
  _s('sh_amt',fmt(grand));
