<script>
var WORK=29,OFF=27,CYCLE=56;
var ARM=['يناير','فبراير','مارس','أبريل','مايو','يونيو','يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'];
var ENM=['January','February','March','April','May','June','July','August','September','October','November','December'];
var ARWD=['أح','إث','ثل','أر','خم','جم','سب'];
var ENWD=['Su','Mo','Tu','We','Th','Fr','Sa'];
var HM=['محرم','صفر','ربيع الأول','ربيع الآخر','جمادى الأولى','جمادى الآخرة','رجب','شعبان','رمضان','شوال','ذو القعدة','ذو الحجة'];

/* HIJRI */
function g2h(gy,gm,gd){var j1=Math.floor((14-gm)/12);var y=gy+4800-j1;var m=gm+12*j1-3;var jdn=gd+Math.floor((153*m+2)/5)+365*y+Math.floor(y/4)-Math.floor(y/100)+Math.floor(y/400)-32045;var l=jdn-1948440+10632;var n=Math.floor((l-1)/10631);l=l-10631*n+354;var j=Math.floor((10985-l)/5316)*Math.floor((50*l)/17719)+Math.floor(l/5670)*Math.floor((43*l)/15238);l=l-Math.floor((30-j)/15)*Math.floor((17719*j)/50)-Math.floor(j/16)*Math.floor((15238*j)/43)+29;var hm=Math.floor((24*l)/709);var hd=l-Math.floor((709*hm)/24);var hy=30*n+j-30;return{y:hy,m:hm,d:hd};}
function hijriLong(date){try{var h=g2h(date.getFullYear(),date.getMonth()+1,date.getDate());return h.d+' '+HM[h.m-1]+' '+h.y+' هـ';}catch(e){return '';}}
function hijriShort(date){try{var h=g2h(date.getFullYear(),date.getMonth()+1,date.getDate());return HM[h.m-1]+' '+h.y+' هـ';}catch(e){return '';}}

