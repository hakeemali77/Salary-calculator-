/* CYCLE MATH */
function getCycle(idx){var s=new Date(cfg.startDate);s.setHours(0,0,0,0);var start=new Date(s.getTime()+idx*CYCLE*86400000);var end=new Date(start.getTime()+(WORK-1)*86400000);return{start:start,end:end};}
function getCurrentIdx(){var today=new Date();today.setHours(0,0,0,0);var s=new Date(cfg.startDate);s.setHours(0,0,0,0);var diff=Math.floor((today-s)/86400000);return diff<0?0:Math.floor(diff/CYCLE);}

/* HOLIDAY HELPERS */
function holsInRange(from,to){var r=[];for(var i=0;i<holidays.length;i++){if(new Date(holidays[i].from)<=to&&new Date(holidays[i].to)>=from)r.push(holidays[i]);}return r;}
function getHolType(ds){for(var i=0;i<holidays.length;i++){if(ds>=holidays[i].from&&ds<=holidays[i].to)return holidays[i].type;}return null;}
function buildSpSet(from,to){
  var set=new Set();
  var cur=new Date(from.getTime());
  while(cur<=to){if(cur.getDay()===5)set.add(cur.toISOString().slice(0,10));cur.setDate(cur.getDate()+1);}
  for(var i=0;i<holidays.length;i++){if(holidays[i].type==='reminder')continue;var hf=new Date(holidays[i].from);var ht=new Date(holidays[i].to);var fd=new Date(Math.max(hf.getTime(),from.getTime()));if(fd.getTime()<=Math.min(ht.getTime(),to.getTime()))set.add(fd.toISOString().slice(0,10));}
  return set;
}

/* SPLIT BY MONTH — full base per month */
function splitByMonth(start,end,spSet){
  var months=cfg.lang==='ar'?ARM:ENM;
  var segs=[];
  var cur=new Date(start.getTime());
  while(cur<=end){
    var mk=cur.getMonth()+'-'+cur.getFullYear();
    var seg=null;for(var x=0;x<segs.length;x++){if(segs[x].mk===mk){seg=segs[x];break;}}
    if(!seg){seg={mk:mk,name:months[cur.getMonth()]+' '+cur.getFullYear(),hij:hijriShort(new Date(cur.getFullYear(),cur.getMonth(),1)),n:0,sp:0,tot:0};segs.push(seg);}
    var ds=cur.toISOString().slice(0,10);
    if(spSet.has(ds))seg.sp++;else seg.n++;
    seg.tot++;
    cur.setDate(cur.getDate()+1);
  }
  for(var i=0;i<segs.length;i++){var s=segs[i];s.nPay=s.n*cfg.workRate;s.spPay=s.sp*cfg.holRate;s.mTot=cfg.base+s.nPay+s.spPay;}
  return segs;
}

