    slides[obIdx].classList.remove('active');
    slides[obIdx].classList.add('exit');
    (function(p){setTimeout(function(){try{slides[p].classList.remove('exit');}catch(e){}},400);}(obIdx));
    obIdx++;
    slides[obIdx].classList.add('active');
    for(var i=0;i<dots.length;i++) dots[i].classList.toggle('active',i===obIdx);
    if(obIdx===slides.length-1){
      var nb=document.getElementById('obNext');var sk=document.getElementById('obSkip');
      if(nb)nb.textContent=cfg.lang==='ar'?'🚀 ابدأ الآن':'🚀 Start Now';
