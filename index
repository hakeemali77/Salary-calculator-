/* NOTIFICATIONS */
function saveNotifSettings(){
  var sel=document.getElementById('notifDays');
  if(sel) cfg.notifDays=parseInt(sel.value)||3;
  save();
  if(cfg.notifOn) scheduleNotif();
}
function toggleNotif(){
  if(!cfg.notifOn){
    if(!('Notification' in window)){showToast(cfg.lang==='ar'?'المتصفح لا يدعم الإشعارات':'Notifications not supported');return;}
    Notification.requestPermission(function(perm){
      if(perm==='granted'){
        cfg.notifOn=true;save();updateNotifUI();scheduleNotif();
        showToast(cfg.lang==='ar'?'✅ تم تفعيل الإشعارات':'✅ Notifications enabled');
      }else{
        showToast(cfg.lang==='ar'?'⚠️ تم رفض الإذن — فعّل من إعدادات المتصفح':'⚠️ Permission denied');
      }
    });
  }else{
    cfg.notifOn=false;save();updateNotifUI();
    showToast(cfg.lang==='ar'?'🔕 تم إيقاف الإشعارات':'🔕 Notifications disabled');
  }
}
function updateNotifUI(){
  var btn=document.getElementById('notifToggle');
  if(btn) btn.className='notif-toggle'+(cfg.notifOn?' on':'');
  var sel=document.getElementById('notifDays');
  if(sel) sel.value=String(cfg.notifDays||3);
  var sub=document.getElementById('set_notifSub');
  if(sub) sub.textContent=cfg.lang==='ar'?('قبل '+cfg.notifDays+' أيام من بداية الدوام'):(''+cfg.notifDays+' days before shift starts');
}
function scheduleNotif(){
  if(!cfg.notifOn||!cfg.startDate) return;
  try{
    var curIdx=getCurrentIdx();
    // Next shift start = end of current cycle + 1 (off days) + start of next
    var cy=getCycle(curIdx);
    var nextStart=new Date(cy.end.getTime()+86400000); // day after end = off period starts
    var nextShiftStart=new Date(nextStart.getTime()+OFF*86400000); // after off days
    var notifTime=new Date(nextShiftStart.getTime()-(cfg.notifDays||3)*86400000);
    notifTime.setHours(8,0,0,0); // 8 AM
    var now=new Date();
    var diff=notifTime-now;
    if(diff>0&&diff<7*24*3600000){ // within next 7 days
      setTimeout(function(){
        try{
          var msg=cfg.lang==='ar'?('🔔 دوامك القادم يبدأ بعد '+(cfg.notifDays||3)+' أيام'):('🔔 Your shift starts in '+(cfg.notifDays||3)+' days');
          new Notification(cfg.lang==='ar'?'حاسبة الراتب 👷':'Salary Calculator 👷',{body:msg,icon:'data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>👷</text></svg>'});
        }catch(e){}
      },diff);
    }
    // Also check if notification should fire now
    checkNotifNow();
  }catch(e){}
}
function checkNotifNow(){
  if(!cfg.notifOn||!cfg.startDate) return;
  try{
    var curIdx=getCurrentIdx();
    var cy=getCycle(curIdx);
    var nextShiftStart=new Date(cy.end.getTime()+(OFF+1)*86400000);
    nextShiftStart.setHours(0,0,0,0);
    var daysUntil=Math.ceil((nextShiftStart-new Date())/86400000);
    var lastNotif=0;
    try{lastNotif=parseInt(localStorage.getItem('oilrig_lastNotif')||'0');}catch(e){}
    if(daysUntil<=cfg.notifDays&&daysUntil>0&&lastNotif!==curIdx+1){
      try{localStorage.setItem('oilrig_lastNotif',String(curIdx+1));}catch(e){}
      var msg=cfg.lang==='ar'?('دوامك القادم يبدأ بعد '+daysUntil+' '+(daysUntil===1?'يوم':'أيام')):('Your next shift starts in '+daysUntil+' day'+(daysUntil!==1?'s':''));
      try{new Notification(cfg.lang==='ar'?'حاسبة الراتب 👷':'Salary Calc 👷',{body:'🔔 '+msg});}catch(e){}
    }
  }catch(e){}
}
var _tt;
function showToast(msg){try{var el=document.getElementById('toast');if(!el)return;el.textContent=msg;el.classList.add('show');clearTimeout(_tt);_tt=setTimeout(function(){el.classList.remove('show');},2500);}catch(e){}}
