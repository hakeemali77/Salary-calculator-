      h+='<div class="cal-legend">';
      for(var li=0;li<legs.length;li++)h+='<div class="cal-leg"><div class="cal-leg-dot" style="background:'+legs[li].bg+';border:'+legs[li].bd+'"></div>'+t.calLeg[li]+'</div>';
      h+='</div>';
    }
    h+='</div>';
  }
  var el=document.getElementById('calContainer');if(el)el.innerHTML=h;
}

